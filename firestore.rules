rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isValidFileOwner() {
      return request.resource.data.userId == request.auth.uid;
    }

    // 1. SETTINGS COLLECTION
    match /Settings/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 2. DEVICES COLLECTION
    match /Devices/{documentId} {
      // Owner can read, update, and delete their own claimed devices
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      // Any authenticated user can read unclaimed devices (for the claim flow)
      allow read: if request.auth != null && resource.data.status == "unclaimed";
      // Any authenticated user can claim an unclaimed device (must assign to own UID)
      allow update: if request.auth != null && resource.data.status == "unclaimed" && request.resource.data.userId == request.auth.uid;
      // Owner can create devices directly (backward compatibility)
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // 3. SENSOR LOGS & ANALYTICS ALERTS
    match /SensorLogs/{logId} {
      allow read: if request.auth != null;
      allow write: if false; // Physically blocks hackers from faking sensor data
    }

    match /AnalyticsAlerts/{alertId} {
      allow read: if request.auth != null;
      allow create, update: if false; // Only Cloud Functions can generate alerts
      allow delete: if request.auth != null; // Allow authenticated users to dismiss
    }

    // 4. FILE METADATA COLLECTION
    match /Metadata/backup_state {
      allow read: if isAuthenticated(); // Allow users to see backup status if needed
      allow write: if false; // Only Cloud Functions (Admin SDK) can update this
    }
    
    // Block all other manual metadata access
    match /FileMetadata/{fileId} { allow read, write: if false; }
    match /Users/{userId}/FileMetadata/{fileId} { allow read, write: if false; }

  }
}
