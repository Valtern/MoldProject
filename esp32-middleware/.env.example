# Server Configuration
PORT=3000

# Security (Authentication)
# Pre-Shared Key (PSK) required in the x-esp32-api-key header of incoming requests.
ESP32_API_KEY=your_secure_randomly_generated_api_key_123


GOOGLE_APPLICATION_CREDENTIALS=path_to_the_json_file_creds_gotten_from_fire_base
# Firebase Configuration
# Option A (Recommended for Local/VMs): Path to your downloaded Firebase Service Account JSON file.
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/your/firebase-adminsdk.json

# Option B (Recommended for PaaS/Serverless like Vercel, Render, Heroku): 
# Provide the entire JSON file content as a single stringified environment variable.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"...","universe_domain":"googleapis.com"}
